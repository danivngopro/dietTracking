{
  "name": "diet-tracking",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @diet/api --filter @diet/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "check:workspace": "node scripts/check-workspace.mjs",
    "db:migrate": "pnpm --filter @diet/api prisma:migrate",
    "db:seed": "pnpm --filter @diet/api prisma:seed",
    "db:validate": "pnpm --filter @diet/api prisma:validate"
  }
}

