generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FoodSource {
  SYSTEM
  USER
}

enum ServingUnit {
  GRAM
  MILLILITER
  PIECE
  SCOOP
}

enum MealLabel {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  OTHER
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  timezone     String       @default("Asia/Jerusalem")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  target       MacroTarget?
  foods        Food[]
  meals        Meal[]
  plans        MealPlan[]
  logs         FoodLog[]
}

model MacroTarget {
  id            String   @id @default(cuid())
  userId        String   @unique
  calories      Decimal  @db.Decimal(12, 3)
  protein       Decimal  @db.Decimal(12, 3)
  carbs         Decimal  @db.Decimal(12, 3)
  fat           Decimal  @db.Decimal(12, 3)
  currentWeight Decimal? @db.Decimal(12, 3)
  goalWeight    Decimal? @db.Decimal(12, 3)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Food {
  id          String       @id @default(cuid())
  slug        String?      @unique
  userId      String?
  source      FoodSource
  name        String
  brand       String?
  servingSize Decimal      @db.Decimal(12, 3)
  servingUnit ServingUnit
  calories    Decimal      @db.Decimal(12, 3)
  protein     Decimal      @db.Decimal(12, 3)
  carbs       Decimal      @db.Decimal(12, 3)
  fat         Decimal      @db.Decimal(12, 3)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User?        @relation(fields: [userId], references: [id], onDelete: Restrict)
  mealItems   MealItem[]
  planItems   MealPlanItem[]
  logs        FoodLog[]

  @@index([userId, name])
  @@index([source, name])
}

model Meal {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       MealItem[]
  planItems   MealPlanItem[]
  logs        FoodLog[]

  @@index([userId, name])
}

model MealItem {
  id       String  @id @default(cuid())
  mealId   String
  foodId   String
  quantity Decimal @db.Decimal(12, 3)
  meal     Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food     Food    @relation(fields: [foodId], references: [id], onDelete: Restrict)

  @@index([foodId])
}

model MealPlan {
  id        String         @id @default(cuid())
  userId    String
  name      String
  date      DateTime       @db.Date
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     MealPlanItem[]

  @@unique([userId, date])
  @@index([userId, date])
}

model MealPlanItem {
  id          String     @id @default(cuid())
  mealPlanId  String
  foodId      String?
  mealId      String?
  quantity    Decimal    @db.Decimal(12, 3)
  plannedTime String?
  mealLabel   MealLabel?
  notes       String?
  mealPlan    MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  food        Food?      @relation(fields: [foodId], references: [id], onDelete: Restrict)
  meal        Meal?      @relation(fields: [mealId], references: [id], onDelete: Restrict)
  log         FoodLog?

  @@index([foodId])
  @@index([mealId])
}

model FoodLog {
  id                         String        @id @default(cuid())
  userId                     String
  foodId                     String?
  mealId                     String?
  mealPlanItemId             String?       @unique
  quantity                   Decimal       @db.Decimal(12, 3)
  eatenAt                    DateTime       @db.Timestamptz(3)
  caloriesSnapshot           Decimal       @db.Decimal(12, 3)
  proteinSnapshot            Decimal       @db.Decimal(12, 3)
  carbsSnapshot              Decimal       @db.Decimal(12, 3)
  fatSnapshot                Decimal       @db.Decimal(12, 3)
  sourceNameSnapshot         String
  servingDescriptionSnapshot String?
  notes                      String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  user                       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  food                       Food?         @relation(fields: [foodId], references: [id], onDelete: Restrict)
  meal                       Meal?         @relation(fields: [mealId], references: [id], onDelete: Restrict)
  mealPlanItem               MealPlanItem? @relation(fields: [mealPlanItemId], references: [id], onDelete: SetNull)

  @@index([userId, eatenAt])
  @@index([foodId])
  @@index([mealId])
}

