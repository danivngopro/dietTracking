DATABASE_URL=postgresql://diet:diet_local_password@localhost:5432/diet_tracking
POSTGRES_DB=diet_tracking
POSTGRES_USER=diet
POSTGRES_PASSWORD=diet_local_password
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
# Must be at least 32 random characters. API will refuse to start in production without this.
JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_COOKIE_NAME=diet_session
NEXT_PUBLIC_API_URL=/api
# Optional: override cookie lifetime in milliseconds (default: 604800000 = 7 days)
# COOKIE_MAX_AGE_MS=604800000
# Optional: set cookie domain for cross-subdomain auth (e.g. .example.com)
# COOKIE_DOMAIN=

